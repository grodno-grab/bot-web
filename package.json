{
  "name": "bot-web",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "postinstall": "node scripts/patch-deps.mjs",
    "start": "vite",
    "build": "vite build",
    "deploy": "node scripts/deploy.mjs",
