#!/usr/bin/env node
'use strict';
const fs   = require('fs');
const path = require('path');

const ROOT  = path.resolve(__dirname, '..');
// Source dir: tmp/ by default (tdweb.js + workers); output goes to project root.
const srcDir = process.argv[2] || path.join(ROOT, 'tmp');
const outDir = process.argv[3] || ROOT;
const ls  = fs.readdirSync(srcDir);

// Locate worker files by pattern (content-hash filenames)
const mainName  = ls.find(f => /^\w+\.worker\.js$/.test(f) && !/^\d+\./.test(f));
const chunkName = ls.find(f => /^\d+\.\w+\.worker\.js$/.test(f));

if (!mainName)  { console.error('ERROR: main worker file not found in ' + srcDir); process.exit(1); }
if (!chunkName) { console.error('ERROR: chunk worker file not found in ' + srcDir); process.exit(1); }

const tdwebPath  = path.join(srcDir, 'tdweb.js');
const outputPath = path.join(outDir, 'tdweb.inlined.js');

if (!fs.existsSync(tdwebPath)) { console.error('ERROR: tdweb.js not found in ' + srcDir); process.exit(1); }

const mainWorker  = fs.readFileSync(path.join(srcDir, mainName),  'utf8');
const chunkWorker = fs.readFileSync(path.join(srcDir, chunkName), 'utf8');
const tdweb       = fs.readFileSync(tdwebPath, 'utf8');

// Step 1: inline chunk worker into main worker.
// The main worker loads chunk 1 via a synchronous importScripts() call.
// importScripts is synchronous, so inlining the chunk as an IIFE is equivalent.
const importScriptsRe = /importScripts\(__webpack_require__\.p[^)]+\)/;
if (!importScriptsRe.test(mainWorker)) {
  console.error('ERROR: importScripts pattern not found in main worker — file structure changed?');
  process.exit(1);
}
const merged = mainWorker.replace(importScriptsRe, `(function(){${chunkWorker}})()`);

// Prepend a fetch patcher so the blob-worker can resolve relative URLs.
// Workers spawned from blob: URLs have no origin, so any relative fetch() call
// (e.g. for the WASM file passed via TdClient's wasmUrl option) would fail with
// "Failed to parse URL". The factory in Step 2 injects the page's directory as
// self.__tdBase at the moment new Worker() is called (main thread has location).
// Kept intentionally minified — this code is embedded verbatim in tdweb.inlined.js.
const fetchPatch =
  `(function(){` +
  `var _f=self.fetch.bind(self);` +
  `self.fetch=function(u,o){` +
  `if(typeof u==='string'&&!/^(https?:|blob:|data:)/.test(u))u=(self.__tdBase||'')+u;` +
  `return _f(u,o);` +
  `};` +
  `}());\n`;
const mergedPatched = fetchPatch + merged;

// Step 2: inline merged worker into tdweb.js.
// Targets the webpack worker factory (module #7 in tdweb.js):
//   module.exports = function() { return new Worker(__webpack_require__.p + "HASH.worker.js"); };
// Replaced with a factory that builds a fresh Blob URL on each call. The blob
// is built in the main thread so location.href is available to inject __tdBase.
const workerModuleRe = /module\.exports = function\(\) \{\s*return new Worker\(__webpack_require__\.p \+ "[^"]+\.worker\.js"\);\s*\};/;
if (!workerModuleRe.test(tdweb)) {
  console.error('ERROR: worker module pattern not found in tdweb.js — file structure changed?');
  process.exit(1);
}
const inlined = tdweb.replace(
  workerModuleRe,
  `module.exports=(function(){` +
  `var _c=${JSON.stringify(mergedPatched)};` +
  `return function(){` +
  `var _b=new Blob(` +
  `['self.__tdBase='+JSON.stringify(location.href.slice(0,location.href.lastIndexOf('/')+1))+';'+_c],` +
  `{type:'application/javascript'}` +
  `);` +
  `return new Worker(URL.createObjectURL(_b));` +
  `};` +
  `}());`
);

fs.writeFileSync(outputPath, inlined, 'utf8');

// Copy WASM file with a stable name (strip the content-hash prefix)
const wasmSrc = ls.find(f => f.endsWith('.wasm'));
if (!wasmSrc) { console.error('ERROR: .wasm file not found in ' + srcDir); process.exit(1); }
const wasmDst = path.join(outDir, 'tdlib.wasm');
fs.copyFileSync(path.join(srcDir, wasmSrc), wasmDst);

console.log('Created: ' + outputPath);
console.log('Created: ' + wasmDst + '  (from ' + wasmSrc + ')');
console.log('  ' + mainName  + '  ' + (mainWorker.length  / 1024).toFixed(1) + ' KB');
console.log('  ' + chunkName + '  ' + (chunkWorker.length / 1024).toFixed(1) + ' KB');
console.log('  tdweb.js          ' + (tdweb.length   / 1024).toFixed(1) + ' KB');
console.log('  tdweb.inlined.js  ' + (inlined.length  / 1024).toFixed(1) + ' KB');
