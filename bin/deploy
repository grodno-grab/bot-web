#!/usr/bin/env node
const dotenv = require('dotenv');
dotenv.config();

const { createHash } = require('crypto');
const { readFileSync, writeFileSync } = require('fs');
const { resolve } = require('path');
const { gzipSync, gunzipSync } = require('zlib');
const S3 = require('aws-sdk/clients/s3');
const mime = require('mime-types');

const s3 = new S3({
  signatureVersion: 'v4',
  accessKeyId: process.env.S3_KEY,
  secretAccessKey: process.env.S3_SECRET,
});

const WASM         = '5e206a8f21790c38ae50cf54b7b9aca7.wasm';
const WORKER_MAIN  = 'ce70fb8f3c7a4342d115.worker.js';
const WORKER_CHUNK = '1.ce70fb8f3c7a4342d115.worker.js';

// Static assets uploaded first; VersionIds are captured for index.html patching.
const STATIC_FILES = ['styles.css', 'tdweb.js', WASM, WORKER_MAIN, WORKER_CHUNK];

const ROOT = resolve(__dirname, '..');

// Upload a file from disk; returns its S3 VersionId.
// Downloads the current S3 object, decompresses it, and compares with local content.
// Skips upload if content is identical; returns the existing VersionId in that case.
const uploadFile = async (filename) => {
  const localContent = readFileSync(`${ROOT}/${filename}`);
  const bucket = process.env.S3_BUCKET;

  try {
    const obj = await s3.getObject({ Bucket: bucket, Key: filename }).promise();
    if (gunzipSync(obj.Body).equals(localContent)) {
      console.info(`Skipped:  ${filename}  (unchanged)`);
      return null;
    }
  } catch (e) {
    if (e.code !== 'NoSuchKey' && e.statusCode !== 404) throw e;
  }

  const data = await s3.upload({
    Bucket: bucket,
    Key: filename,
    Body: gzipSync(localContent),
    ContentType: mime.lookup(filename) || 'application/octet-stream',
    ContentEncoding: 'gzip',
  }).promise();
  console.info(`Uploaded: ${filename}  →  ${data.VersionId}`);
  return data.VersionId;
};

// Upload an in-memory HTML string; returns S3 VersionId.
const uploadHtml = (content, key) => new Promise((res, rej) => {
  s3.upload({
    Bucket: process.env.S3_BUCKET,
    Key: key,
    Body: gzipSync(Buffer.from(content)),
    ContentType: 'text/html',
    ContentEncoding: 'gzip',
  }).promise().then((data) => {
    console.info(`Uploaded: index.html  →  ${key}  (${data.VersionId})`);
    res(data.VersionId);
  }).catch(rej);
});

const escRe = (s) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

const computeIntegrity = (filename) => {
  const hash = createHash('sha384').update(readFileSync(`${ROOT}/${filename}`)).digest('base64');
  return `sha384-${hash}`;
};

// Patch index.html in memory: inject S3 VersionIds into asset URLs and worker mapping.
// null values mean the file was unchanged — leave its existing versionId in index.html as-is.
const patchIndex = (html, { styles, tdweb, wasm, main, chunk, stylesIntegrity }) => {
  if (tdweb !== null)
    html = html.replace(/src="tdweb\.js[^"]*"/, `src="tdweb.js?versionId=${tdweb}"`);
  if (styles !== null)
    html = html.replace(/href="styles\.css[^"]*"\s+integrity="[^"]*"/, `href="styles.css?versionId=${styles}" integrity="${stylesIntegrity}"`);
  if (wasm !== null)
    html = html.replace(/wasmUrl: '[^']*\.wasm[^']*'/, `wasmUrl: '${WASM}?versionId=${wasm}'`);
  if (main !== null)
    html = html.replace(new RegExp(`'${escRe(WORKER_MAIN)}':\\s*(null|'[^']*')`),  `'${WORKER_MAIN}': '${main}'`);
  if (chunk !== null)
    html = html.replace(new RegExp(`'${escRe(WORKER_CHUNK)}':\\s*(null|'[^']*')`), `'${WORKER_CHUNK}': '${chunk}'`);
  return html;
};

(async () => {
  try {
    console.info('Uploading static assets to S3...\n');
    const [styles, tdweb, wasm, main, chunk] =
      await Promise.all(STATIC_FILES.map(uploadFile));

    console.info('\nPatching and uploading index.html...');
    const stylesIntegrity = styles !== null ? computeIntegrity('styles.css') : null;
    const html = readFileSync(`${ROOT}/index.html`, 'utf8');
    const patched = patchIndex(html, { styles, tdweb, wasm, main, chunk, stylesIntegrity });

    // versionIds may be unchanged, but the HTML body itself could have changed — check S3.
    let s3HtmlUnchanged = false;
    if (patched === html) {
      try {
        const obj = await s3.getObject({ Bucket: process.env.S3_BUCKET, Key: 'index.html' }).promise();
        s3HtmlUnchanged = gunzipSync(obj.Body).toString('utf8') === patched;
      } catch (e) {
        if (e.code !== 'NoSuchKey' && e.statusCode !== 404) throw e;
      }
    }

    if (s3HtmlUnchanged) {
      const tHead = await s3.headObject({ Bucket: process.env.S3_BUCKET, Key: 't' }).promise();
      const tVersionId = tHead.VersionId;
      console.info('Skipped:  index.html  (unchanged)');
      console.info(`\nhttps://s3.amazonaws.com/${process.env.S3_BUCKET}/t?versionId=${tVersionId}`);
    } else {
      writeFileSync(`${ROOT}/index.html`, patched, 'utf8');
      console.info('Patched: index.html');

      const [, tVersionId] = await Promise.all([
        uploadHtml(patched, 'index.html'),
        uploadHtml(patched, 't'),
      ]);

      console.info('\nPatching README files...');
      const patchReadme = (content) =>
        content.replace(/\/t\.t\/t\?versionId=[^\s`'")\]]+/g, `/t.t/t?versionId=${tVersionId}`);
      for (const name of ['README.md', 'README.ru.md']) {
        const filePath = `${ROOT}/${name}`;
        writeFileSync(filePath, patchReadme(readFileSync(filePath, 'utf8')), 'utf8');
        console.info(`Patched: ${name}`);
      }

      console.info(`\nhttps://s3.amazonaws.com/${process.env.S3_BUCKET}/t?versionId=${tVersionId}`);
    }
    console.info('\nDone.');
  } catch (e) {
    console.error(e.message);
    process.exit(1);
  }
})();
